<UserControl x:Class="Metraj.Views.EnKesitAlanControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF1E1E2E">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- İstasyon -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
            <TextBlock Text="İstasyon:" Foreground="#FFDCDCDC" FontFamily="Segoe UI"
                       FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Text="{Binding Istasyon, UpdateSourceTrigger=PropertyChanged}"
                     Width="100" FontFamily="Segoe UI" FontSize="11" Padding="4,2"/>
        </StackPanel>

        <!-- 3 Action buttons -->
        <StackPanel Grid.Row="1" Margin="0,0,0,5">
            <WrapPanel Margin="0,0,0,3">
                <Button Content="İki Çizgi Seç" Command="{Binding IkiCizgiSecCommand}"
                        Padding="8,5" Margin="0,0,5,0" Background="#FF0078D4" Foreground="White"
                        FontFamily="Segoe UI" FontSize="11" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Nesne Seç" Command="{Binding KapaliNesneSecCommand}"
                        Padding="8,5" Margin="0,0,5,0" Background="#FF0078D4" Foreground="White"
                        FontFamily="Segoe UI" FontSize="11" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Tıkla ve Hesapla" Command="{Binding NoktaTiklaSurekliCommand}"
                        Padding="8,5" Background="#FF0078D4" Foreground="White"
                        FontFamily="Segoe UI" FontSize="11" BorderThickness="0" Cursor="Hand"/>
            </WrapPanel>
            <TextBlock Text="Tıkla ve Hesapla: Kapalı bölgelere ardı ardına tıklayın, ESC ile çıkın"
                       Foreground="#FF6A6A8A" FontFamily="Segoe UI" FontSize="9" FontStyle="Italic"/>
        </StackPanel>

        <!-- Results DataGrid -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Katmanlar}" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                  Background="#FF2D2D44" Foreground="#FFDCDCDC" BorderBrush="#FF3D3D5C"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#FF3D3D5C"
                  RowBackground="#FF2D2D44" AlternatingRowBackground="#FF252540"
                  FontFamily="Segoe UI" FontSize="11" HeadersVisibility="Column"
                  ColumnHeaderHeight="28" RowHeight="24">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FF3D3D5C"/>
                    <Setter Property="Foreground" Value="#FFDCDCDC"/>
                    <Setter Property="Padding" Value="5,3"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderBrush" Value="#FF4D4D6C"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Malzeme" Binding="{Binding MalzemeAdi}" Width="*"/>
                <DataGridTextColumn Header="Alan (m²)" Binding="{Binding Alan, StringFormat=F2}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,5,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Yöntem" Binding="{Binding Yontem}" Width="75"/>
                <DataGridTextColumn Header="Katman" Binding="{Binding KatmanAdi}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Total -->
        <Border Grid.Row="3" Background="#FF3D3D5C" CornerRadius="3" Margin="0,5,0,0" Padding="8,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Toplam Alan:" Foreground="#FFDCDCDC"
                           FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding ToplamAlan, StringFormat={}{0:F2} m²}"
                           Foreground="#FF4EC9B0" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Status + Clear -->
        <DockPanel Grid.Row="4" Margin="0,5,0,0">
            <Button DockPanel.Dock="Right" Content="Temizle" Command="{Binding TemizleCommand}"
                    Padding="10,4" Background="#FF4D4D6C" Foreground="#FFDCDCDC"
                    FontFamily="Segoe UI" FontSize="11" BorderThickness="0" Cursor="Hand"/>
            <TextBlock Text="{Binding DurumMesaji}" Foreground="#FF8888AA" FontFamily="Segoe UI"
                       FontSize="10" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
        </DockPanel>
    </Grid>
</UserControl>
