<UserControl x:Class="Metraj.Views.HacimControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF1E1E2E">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Buttons row -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,5">
            <Button Content="Manuel Ekle" Command="{Binding EnkesitEkleCommand}"
                    Padding="8,4" Margin="0,0,5,0" Background="#FF0078D4" Foreground="White"
                    FontFamily="Segoe UI" FontSize="11" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Polyline'dan Al" Command="{Binding PolylinedenAlanAlCommand}"
                    Padding="8,4" Margin="0,0,5,0" Background="#FF0078D4" Foreground="White"
                    FontFamily="Segoe UI" FontSize="11" BorderThickness="0" Cursor="Hand"/>
        </WrapPanel>

        <!-- Method selection + Calculate -->
        <DockPanel Grid.Row="1" Margin="0,0,0,5">
            <Button DockPanel.Dock="Right" Content="Hesapla" Command="{Binding HesaplaCommand}"
                    Padding="12,4" Background="#FF107C10" Foreground="White"
                    FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Metot:" Foreground="#FFDCDCDC" FontFamily="Segoe UI" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox Width="130" FontSize="11" SelectedIndex="0" x:Name="MetotCombo"
                          SelectionChanged="MetotCombo_SelectionChanged">
                    <ComboBoxItem Content="Ortalama Alan" Tag="OrtalamaAlan"/>
                    <ComboBoxItem Content="Prismoidal" Tag="Prismoidal"/>
                </ComboBox>
            </StackPanel>
        </DockPanel>

        <!-- En Kesit input grid -->
        <GroupBox Grid.Row="2" Header="En Kesitler" Foreground="#FFDCDCDC" FontFamily="Segoe UI" FontSize="11"
                  BorderBrush="#FF3D3D5C">
            <DataGrid ItemsSource="{Binding Enkesitler}" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False"
                      Background="#FF2D2D44" Foreground="#FFDCDCDC" BorderBrush="#FF3D3D5C"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#FF3D3D5C"
                      RowBackground="#FF2D2D44" AlternatingRowBackground="#FF252540"
                      FontSize="11" HeadersVisibility="Column" ColumnHeaderHeight="26" RowHeight="22">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#FF3D3D5C"/>
                        <Setter Property="Foreground" Value="#FFDCDCDC"/>
                        <Setter Property="Padding" Value="5,2"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderBrush" Value="#FF4D4D6C"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Istasyon" Binding="{Binding Istasyon, StringFormat=F3}" Width="100"/>
                    <DataGridTextColumn Header="Alan (m²)" Binding="{Binding ToplamAlan, StringFormat=F2}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="0,0,5,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Separator -->
        <TextBlock Grid.Row="3" Text="Hesaplama Sonuclari" Foreground="#FF4EC9B0"
                   FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Margin="0,5,0,3"/>

        <!-- Results grid -->
        <DataGrid Grid.Row="4" ItemsSource="{Binding Segmentler}" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserAddRows="False"
                  Background="#FF2D2D44" Foreground="#FFDCDCDC" BorderBrush="#FF3D3D5C"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#FF3D3D5C"
                  RowBackground="#FF2D2D44" AlternatingRowBackground="#FF252540"
                  FontSize="11" HeadersVisibility="Column" ColumnHeaderHeight="26" RowHeight="22">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FF3D3D5C"/>
                    <Setter Property="Foreground" Value="#FFDCDCDC"/>
                    <Setter Property="Padding" Value="5,2"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderBrush" Value="#FF4D4D6C"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ist.1" Binding="{Binding Istasyon1, StringFormat=F1}" Width="60"/>
                <DataGridTextColumn Header="Ist.2" Binding="{Binding Istasyon2, StringFormat=F1}" Width="60"/>
                <DataGridTextColumn Header="A1 (m²)" Binding="{Binding Alan1, StringFormat=F2}" Width="70"/>
                <DataGridTextColumn Header="A2 (m²)" Binding="{Binding Alan2, StringFormat=F2}" Width="70"/>
                <DataGridTextColumn Header="Hacim (m³)" Binding="{Binding Hacim, StringFormat=F2}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,5,0"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Total -->
        <Border Grid.Row="5" Background="#FF3D3D5C" CornerRadius="3" Margin="0,5,0,0" Padding="8,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Toplam Hacim:" Foreground="#FFDCDCDC"
                           FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding ToplamHacim, StringFormat={}{0:F2} m³}"
                           Foreground="#FF4EC9B0" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Status + Clear -->
        <DockPanel Grid.Row="6" Margin="0,5,0,0">
            <Button DockPanel.Dock="Right" Content="Temizle" Command="{Binding TemizleCommand}"
                    Padding="10,4" Background="#FF4D4D6C" Foreground="#FFDCDCDC"
                    FontFamily="Segoe UI" FontSize="11" BorderThickness="0" Cursor="Hand"/>
            <TextBlock Text="{Binding DurumMesaji}" Foreground="#FF8888AA" FontFamily="Segoe UI"
                       FontSize="10" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
        </DockPanel>
    </Grid>
</UserControl>
