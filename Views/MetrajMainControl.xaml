<UserControl x:Class="Metraj.Views.MetrajMainControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Metraj.Views"
             Background="#FF1E1E2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FF2D2D44" Padding="10,6">
            <TextBlock Text="Metraj Asistani" Foreground="#FF4EC9B0"
                       FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"/>
        </Border>

        <!-- TabControl -->
        <TabControl Grid.Row="1" x:Name="MainTabControl"
                    Background="#FF1E1E2E" BorderBrush="#FF3D3D5C" Margin="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#FF2D2D44"/>
                    <Setter Property="Foreground" Value="#FF8888AA"/>
                    <Setter Property="Padding" Value="12,5"/>
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FF3D3D5C"/>
                            <Setter Property="Foreground" Value="#FF4EC9B0"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <TabItem Header="Uzunluk">
                <local:UzunlukControl x:Name="UzunlukTab"/>
            </TabItem>
            <TabItem Header="Alan">
                <local:AlanControl x:Name="AlanTab"/>
            </TabItem>
            <TabItem Header="Kübaj">
                <local:HacimControl x:Name="HacimTab"/>
            </TabItem>
            <TabItem Header="Toplama">
                <local:ToplamaControl x:Name="ToplamaTab"/>
            </TabItem>
            <TabItem Header="Ayarlar">
                <local:AyarlarControl x:Name="AyarlarTab"/>
            </TabItem>
        </TabControl>

        <!-- Bottom status bar -->
        <Border Grid.Row="2" Background="#FF2D2D44" Padding="8,4">
            <TextBlock Text="{Binding DurumMesaji}" Foreground="#FF8888AA"
                       FontFamily="Segoe UI" FontSize="10"/>
        </Border>
    </Grid>
</UserControl>
