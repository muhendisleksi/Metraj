<Window x:Class="Metraj.Views.EnkesitOkuma.KesitDogrulamaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Metraj.Views.EnkesitOkuma"
        Title="Kesit Dogrulama"
        Width="1000" Height="650" MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow"
        Background="#FF1E1E2E">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Metraj;component/Views/Styles/DarkThemeStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#FF2D2D44"/>
            <Setter Property="Foreground" Value="#FFCCCCDD"/>
            <Setter Property="BorderBrush" Value="#FF3D3D5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF3D3D5C"/>
                                <Setter Property="Foreground" Value="#FF4EC9B0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF4EC9B0"/>
                                <Setter Property="Foreground" Value="#FF1E1E2E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#FF252535"/>
                                <Setter Property="Foreground" Value="#FF555566"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="#FF1D5C46"/>
            <Setter Property="Foreground" Value="#FF4EC9B0"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="#44E24B4A"/>
            <Setter Property="Foreground" Value="#FFE24B4A"/>
            <Setter Property="BorderBrush" Value="#FFE24B4A"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Ust Toolbar -->
        <Border Grid.Row="0" Background="#FF2D2D44" Padding="8" CornerRadius="4" Margin="0,0,0,4">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Onceki" Command="{Binding OncekiCommand}"
                            Style="{StaticResource DarkButton}" Width="72" Height="26" Margin="0,0,4,0" Padding="4"/>
                    <Button Content="Sonraki" Command="{Binding SonrakiCommand}"
                            Style="{StaticResource DarkButton}" Width="72" Height="26" Margin="0,0,12,0" Padding="4"/>
                    <TextBlock Text="{Binding ToplamGosterilen}" Foreground="#FFCCCCDD"
                               VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding AktifKesitBilgi}" Foreground="#FF8888AA"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Durum badge'leri -->
                    <Border Background="#FF1D5C46" CornerRadius="4" Padding="6,2" Margin="0,0,4,0">
                        <TextBlock Foreground="#FF4EC9B0" FontSize="11">
                            <Run Text="{Binding OnayliSayisi, Mode=OneWay}"/>
                            <Run Text=" onayli"/>
                        </TextBlock>
                    </Border>
                    <Border Background="#FF5C4D1D" CornerRadius="4" Padding="6,2" Margin="0,0,4,0">
                        <TextBlock Foreground="#FFEFB84E" FontSize="11">
                            <Run Text="{Binding UyariSayisi, Mode=OneWay}"/>
                            <Run Text=" bekliyor"/>
                        </TextBlock>
                    </Border>
                    <Border Background="#FF5C1D1D" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                        <TextBlock Foreground="#FFE24B4A" FontSize="11">
                            <Run Text="{Binding SorunluSayisi, Mode=OneWay}"/>
                            <Run Text=" sorunlu"/>
                        </TextBlock>
                    </Border>
                    <CheckBox Content="Sadece sorunlu" IsChecked="{Binding SadeceSorunluGoster}"
                              Foreground="#FFCCCCDD" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Content="Tumunu Onayla" Command="{Binding TumunuOnaylaCommand}"
                            Style="{StaticResource SuccessButton}" Height="26" Padding="8,2"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Alt: Kesit + Detay -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="250"/>
            </Grid.ColumnDefinitions>

            <!-- Sol: Kesit Onizleme -->
            <Border Grid.Column="0" Background="#FF12121E" CornerRadius="4" Margin="0,0,4,0">
                <local:KesitOnizlemeControl x:Name="OnizlemeControl"/>
            </Border>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="#FF3D3D5C"
                          Cursor="SizeWE" ResizeBehavior="PreviousAndNext"/>

            <!-- Sag Panel -->
            <Border Grid.Column="2" Background="#FF2D2D44" CornerRadius="4" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Kiyas Tablosu -->
                    <DataGrid Grid.Row="0" ItemsSource="{Binding AktifKesitKiyaslar}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Background="#FF1E1E2E" Foreground="#FFCCCCDD"
                              HeadersVisibility="Column" BorderBrush="#FF3D3D5C" BorderThickness="1"
                              GridLinesVisibility="Horizontal" RowBackground="#FF1E1E2E"
                              AlternatingRowBackground="#FF252536"
                              HorizontalGridLinesBrush="#FF3D3D5C">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#FF2D2D44"/>
                                <Setter Property="Foreground" Value="#FF8888AA"/>
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="BorderBrush" Value="#FF3D3D5C"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Malzeme" Binding="{Binding MalzemeAdi}" Width="*"/>
                            <DataGridTextColumn Header="Hesap" Binding="{Binding HesaplananAlan, StringFormat=F2}" Width="55"/>
                            <DataGridTextColumn Header="Tablo" Binding="{Binding TabloAlani, StringFormat=F2}" Width="55"/>
                            <DataGridTextColumn Header="Fark" Binding="{Binding Fark, StringFormat=F2}" Width="45"/>
                            <DataGridTemplateColumn Header="%" Width="45">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FarkYuzde, StringFormat={}{0:F1}}"
                                                   Foreground="{Binding DurumRengi}" FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Cizgi Duzelt -->
                    <StackPanel Grid.Row="1" Margin="0,8,0,0">
                        <TextBlock Text="Cizgi Duzelt:" Foreground="#FFCCCCDD" Margin="0,0,0,4" FontSize="12"/>
                        <ComboBox ItemsSource="{Binding MevcutRoller}"
                                  SelectedItem="{Binding YeniRol}" Height="26"/>
                        <Button Content="Rolu Degistir" Command="{Binding CizgiDuzeltCommand}"
                                Style="{StaticResource DarkButton}"
                                Height="26" Margin="0,4,0,0" Padding="4"/>
                    </StackPanel>

                    <!-- Onay Butonlari -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,4">
                        <Button Content="Onayla" Command="{Binding OnaylaCommand}"
                                Style="{StaticResource SuccessButton}"
                                Width="90" Height="32"/>
                        <Button Content="Sorunlu" Command="{Binding SorunluIsaretle}"
                                Style="{StaticResource DangerButton}"
                                Width="90" Height="32" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
