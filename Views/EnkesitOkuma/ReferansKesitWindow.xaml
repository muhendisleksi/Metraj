<Window x:Class="Metraj.Views.EnkesitOkuma.ReferansKesitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Metraj.Views.EnkesitOkuma"
        Title="Referans Kesit — Kalibrasyon"
        Width="900" Height="600" MinWidth="700" MinHeight="450"
        WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow"
        Background="#FF1E1E2E">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sol: Kesit Önizleme -->
        <local:KesitOnizlemeControl x:Name="OnizlemeControl" Grid.Column="0" Margin="4"/>

        <!-- Sağ: Rol Atama -->
        <Border Grid.Column="1" Background="#FF252536" Margin="4" CornerRadius="4" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Bilgi -->
                <TextBlock Grid.Row="0" Text="{Binding SecilenCizgiBilgi}" Foreground="#CCD6E0"
                           FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>

                <!-- Çizgi Listesi -->
                <ListBox Grid.Row="1" ItemsSource="{Binding Cizgiler}"
                         SelectedItem="{Binding SecilenCizgi}"
                         Background="#FF1A1A2A" Foreground="#CCD6E0"
                         BorderThickness="0" Margin="0,0,0,8">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <Rectangle Width="12" Height="12" Margin="0,0,6,0"
                                           Fill="{Binding Rol, Converter={x:Null}}" Opacity="0.8"/>
                                <TextBlock Text="{Binding Rol}" Width="100" Foreground="#CCD6E0"/>
                                <TextBlock Text="{Binding LayerAdi}" Foreground="#8899AA" FontSize="10"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Rol Seçimi -->
                <StackPanel Grid.Row="2" Margin="0,0,0,8">
                    <TextBlock Text="Rol Ata:" Foreground="#CCD6E0" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding MevcutRoller}"
                              SelectedItem="{Binding SecilenRol}"
                              Height="28" FontSize="12"/>
                    <Button Content="Rolü Ata" Command="{Binding RolAta}"
                            Margin="0,4,0,0" Height="28"
                            Background="#FF3D5AFE" Foreground="White" BorderThickness="0"/>
                </StackPanel>

                <!-- Otomatik Ata -->
                <Button Grid.Row="3" Content="Tümünü Otomatik Ata"
                        Command="{Binding TumunuOtomatikAta}"
                        Height="28" Margin="0,0,0,8"
                        Background="#FF43A047" Foreground="White" BorderThickness="0"/>

                <!-- Kaydet / İptal -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Şablona Kaydet" Command="{Binding SablonDosyayaKaydet}"
                            Width="100" Height="28" Margin="0,0,6,0"
                            Background="#FF546E7A" Foreground="White" BorderThickness="0"/>
                    <Button Content="Kaydet" x:Name="BtnKaydet" Click="BtnKaydet_Click"
                            Width="80" Height="28"
                            Background="#FF3D5AFE" Foreground="White" BorderThickness="0"/>
                    <Button Content="İptal" x:Name="BtnIptal" Click="BtnIptal_Click"
                            Width="60" Height="28" Margin="6,0,0,0"
                            Background="#FF424242" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
