<Window x:Class="Metraj.Views.EnkesitOkuma.ReferansKesitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Metraj.Views.EnkesitOkuma"
        Title="Referans Kesit -- Kalibrasyon"
        Width="900" Height="600" MinWidth="700" MinHeight="450"
        WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow"
        Background="#FF1E1E2E">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Metraj;component/Views/Styles/DarkThemeStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
            <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background" Value="#FF2D2D44"/>
            <Setter Property="Foreground" Value="#FFCCCCDD"/>
            <Setter Property="BorderBrush" Value="#FF3D3D5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF3D3D5C"/>
                                <Setter Property="Foreground" Value="#FF4EC9B0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF4EC9B0"/>
                                <Setter Property="Foreground" Value="#FF1E1E2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Background" Value="#FF4EC9B0"/>
            <Setter Property="Foreground" Value="#FF1E1E2E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Kesit navigasyonu -->
        <Border Grid.Row="0" Background="#FF2D2D44" CornerRadius="4" Margin="4,4,4,0" Padding="8,5"
                BorderBrush="#FF3D3D5C" BorderThickness="1"
                Visibility="{Binding NavigasyonAktif, Converter={StaticResource BoolToVisConverter}}">
            <DockPanel>
                <TextBlock Text="Kesit:" Foreground="#FF8888AA" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Content="&#x25C0;" Command="{Binding OncekiKesitCommand}"
                        Style="{StaticResource DarkBtn}" Width="30" Height="26" Padding="2"
                        FontSize="11" ToolTip="Onceki kesit"/>
                <Button Content="&#x25B6;" Command="{Binding SonrakiKesitCommand}"
                        Style="{StaticResource DarkBtn}" Width="30" Height="26" Padding="2"
                        FontSize="11" Margin="4,0,0,0" ToolTip="Sonraki kesit" DockPanel.Dock="Right"/>
                <TextBlock Text="{Binding AktifKesitBilgi}" Foreground="#FF8888AA" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0,0,0" DockPanel.Dock="Right"/>
                <ComboBox ItemsSource="{Binding KesitSecenekleri}"
                          SelectedItem="{Binding SecilenKesitOgesi}"
                          DisplayMemberPath="Gosterim"
                          Height="26" FontSize="11" Margin="8,0,0,0"
                          Background="#FF1E1E2E" Foreground="#FFCCCCDD" BorderBrush="#FF3D3D5C"/>
            </DockPanel>
        </Border>

        <!-- Row 1: Ana icerik -->
        <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="65*" MinWidth="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="35*" MinWidth="250"/>
            </Grid.ColumnDefinitions>

            <!-- Sol: Kesit Onizleme -->
            <Border Grid.Column="0" Background="#FF0A0A14" CornerRadius="4" Margin="4"
                    BorderBrush="#FF3D3D5C" BorderThickness="1">
                <local:KesitOnizlemeControl x:Name="OnizlemeControl"/>
            </Border>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="#FF3D3D5C"
                          Cursor="SizeWE" ResizeBehavior="PreviousAndNext"/>

        <!-- Sag: Malzeme Eslestirme -->
        <Border Grid.Column="2" Background="#FF2D2D44" Margin="4" CornerRadius="4" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Baslik -->
                <TextBlock Grid.Row="0" Text="Malzeme Eslestirme" Foreground="#FFCCCCDD" FontWeight="Bold"
                           FontSize="14" Margin="0,0,0,6"/>

                <!-- Row 1: Tablo — her satir bir Layer+Renk grubu -->
                <ListBox Grid.Row="1" ItemsSource="{Binding LayerRenkGruplari}"
                         SelectedItem="{Binding SecilenGrup}"
                         Background="#FF1E1E2E" BorderBrush="#FF3D3D5C" BorderThickness="1"
                         Margin="0,0,0,6" HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent" Padding="1">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="SatirBorder" BorderThickness="1" Padding="3,4"
                                    BorderBrush="#FF8B6914" Background="#30806000">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="95"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Renk Ellipse -->
                                    <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding WpfRenk}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <!-- Layer Adi + Bilgi -->
                                    <StackPanel Grid.Column="1" Margin="4,0,4,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding LayerAdi}" Foreground="#FFCCCCDD" FontSize="10"
                                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Foreground="#FF8888AA" FontSize="9">
                                            <Run Text="{Binding CizgiSayisi, Mode=OneWay, StringFormat='{}{0} ciz'}"/>
                                            <Run Text=" | "/>
                                            <Run Text="{Binding OrnekBilgi, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- X Araligi -->
                                    <TextBlock Grid.Column="2" Text="{Binding XAraligi}" Foreground="#FF8888AA"
                                               FontSize="8" VerticalAlignment="Center" Margin="0,0,4,0"/>

                                    <!-- Malzeme ComboBox -->
                                    <ComboBox Grid.Column="3" ItemsSource="{Binding DataContext.MevcutRoller, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedItem="{Binding AtananRol}"
                                              Height="22" FontSize="10"
                                              Background="#FF1E1E2E" Foreground="#FFCCCCDD" BorderBrush="#FF3D3D5C"/>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Onaylandi}" Value="True">
                                    <Setter TargetName="SatirBorder" Property="BorderBrush" Value="#FF2D8B57"/>
                                    <Setter TargetName="SatirBorder" Property="Background" Value="#20008040"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Row 2: Tumunu Onayla + Durum -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="Tumunu Onayla" Command="{Binding TumunuOnaylaCommand}"
                            Style="{StaticResource DarkBtn}" Height="24" Padding="8,2" FontSize="10"
                            Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding TopluOnayDurumu}" Foreground="#FF8888AA" FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Row 3: Kaydet / Iptal -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{Binding KaydetButonMetni}" x:Name="BtnKaydet" Click="BtnKaydet_Click"
                            IsEnabled="{Binding TopluTumOnaylandi}"
                            Style="{StaticResource PrimBtn}" Width="100" Height="28" Padding="4"/>
                    <Button Content="Iptal" x:Name="BtnIptal" Click="BtnIptal_Click"
                            Style="{StaticResource DarkBtn}" Width="60" Height="28" Margin="6,0,0,0" Padding="4"/>
                </StackPanel>
            </Grid>
        </Border>
        </Grid>
    </Grid>
</Window>
