<Window x:Class="Metraj.Views.EnkesitOkuma.ReferansKesitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Metraj.Views.EnkesitOkuma"
        Title="Referans Kesit -- Kalibrasyon"
        Width="900" Height="600" MinWidth="700" MinHeight="450"
        WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow"
        Background="#FF1E1E2E">
    <Window.Resources>
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background" Value="#FF2D2D44"/>
            <Setter Property="Foreground" Value="#FFCCCCDD"/>
            <Setter Property="BorderBrush" Value="#FF3D3D5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF3D3D5C"/>
                                <Setter Property="Foreground" Value="#FF4EC9B0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF4EC9B0"/>
                                <Setter Property="Foreground" Value="#FF1E1E2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Background" Value="#FF4EC9B0"/>
            <Setter Property="Foreground" Value="#FF1E1E2E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="65*"/>
            <ColumnDefinition Width="35*"/>
        </Grid.ColumnDefinitions>

        <!-- Sol: Kesit Onizleme -->
        <Border Grid.Column="0" Background="#FF0A0A14" CornerRadius="4" Margin="4"
                BorderBrush="#FF3D3D5C" BorderThickness="1">
            <local:KesitOnizlemeControl x:Name="OnizlemeControl"/>
        </Border>

        <!-- Sag: Cizgi Rolleri -->
        <Border Grid.Column="1" Background="#FF2D2D44" Margin="4" CornerRadius="4" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Baslik -->
                <TextBlock Grid.Row="0" Text="Cizgi rolleri" Foreground="#FFCCCCDD" FontWeight="Bold"
                           FontSize="14" Margin="0,0,0,8"/>

                <!-- Secili cizgi bilgisi -->
                <TextBlock Grid.Row="1" Text="{Binding SecilenCizgiBilgi}" Foreground="#FF8888AA"
                           FontSize="10" Margin="0,0,0,6" TextWrapping="Wrap"/>

                <!-- Cizgi Listesi -->
                <ListBox Grid.Row="2" ItemsSource="{Binding Cizgiler}"
                         SelectedItem="{Binding SecilenCizgi}"
                         Background="#FF1E1E2E" BorderBrush="#FF3D3D5C" BorderThickness="1"
                         Margin="0,0,0,8">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2,1">
                                <Ellipse Width="10" Height="10" Margin="0,0,6,0" VerticalAlignment="Center"
                                         Fill="#FF757575"/>
                                <TextBlock Text="{Binding Rol}" Width="85" Foreground="#FFCCCCDD" FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding LayerAdi}" Foreground="#FF8888AA" FontSize="10"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="4,2"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FF3D3D5C"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF353550"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Rol Secimi -->
                <StackPanel Grid.Row="3" Margin="0,0,0,6">
                    <TextBlock Text="Rol Ata:" Foreground="#FFCCCCDD" Margin="0,0,0,3" FontSize="12"/>
                    <ComboBox ItemsSource="{Binding MevcutRoller}"
                              SelectedItem="{Binding SecilenRol}"
                              Height="26" FontSize="11"
                              Background="#FF2D2D44" Foreground="#FFCCCCDD" BorderBrush="#FF3D3D5C"/>
                    <Button Content="Rolu Ata" Command="{Binding RolAta}"
                            Style="{StaticResource PrimBtn}" Margin="0,4,0,0" Height="26" Padding="4"/>
                </StackPanel>

                <!-- Otomatik Ata -->
                <Button Grid.Row="4" Content="Tumunu Otomatik Ata"
                        Command="{Binding TumunuOtomatikAta}"
                        Style="{StaticResource DarkBtn}" Height="26" Margin="0,0,0,8" Padding="4"
                        Background="#FF2D5A4A" Foreground="#FF4EC9B0" BorderBrush="#FF4EC9B0"/>

                <!-- Kaydet / Iptal -->
                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Kaydet" x:Name="BtnKaydet" Click="BtnKaydet_Click"
                            Style="{StaticResource PrimBtn}" Width="80" Height="28" Padding="4"/>
                    <Button Content="Iptal" x:Name="BtnIptal" Click="BtnIptal_Click"
                            Style="{StaticResource DarkBtn}" Width="60" Height="28" Margin="6,0,0,0" Padding="4"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
