<Window x:Class="Metraj.Views.EnkesitOkuma.KesitSecimWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Referans Kesit Seç"
        Width="340" Height="420" MinWidth="280" MinHeight="300"
        WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow"
        Background="#FF1E1E2E" ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Metraj;component/Views/Styles/DarkThemeStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background" Value="#FF2D2D44"/>
            <Setter Property="Foreground" Value="#FFCCCCDD"/>
            <Setter Property="BorderBrush" Value="#FF3D3D5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF3D3D5C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Background" Value="#FF4EC9B0"/>
            <Setter Property="Foreground" Value="#FF1E1E2E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Foreground="#FF8888AA" FontSize="12" Margin="0,0,0,10"
                   Text="Kalibrasyon için bir kesit seçin. Ortadaki kesitler daha temsil edicidir (ilk/son kesitler karmaşık olabilir)."/>

        <ListBox x:Name="KesitListBox" Grid.Row="1"
                 Background="#FF12121E"
                 DisplayMemberPath="Gosterim"
                 MouseDoubleClick="ListBox_DoubleClick"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Seç" Click="BtnSec_Click" Style="{StaticResource PrimBtn}"
                    Width="80" Height="30"/>
            <Button Content="İptal" Click="BtnIptal_Click" Style="{StaticResource DarkBtn}"
                    Width="70" Height="30" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
