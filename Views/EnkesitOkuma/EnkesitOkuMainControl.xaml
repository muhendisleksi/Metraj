<UserControl x:Class="Metraj.Views.EnkesitOkuma.EnkesitOkuMainControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF1E1E2E" MinWidth="360">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Adım Göstergesi -->
        <Border Grid.Row="0" Background="#FF252536" Padding="8" Margin="4">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <RadioButton Content="1.Seçim" IsChecked="{Binding Adim1Aktif, Mode=OneWay}"
                             Foreground="#CCD6E0" Margin="0,0,6,0" IsEnabled="False"/>
                <TextBlock Text="→" Foreground="#556" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <RadioButton Content="2.Tarama" IsChecked="{Binding Adim2Aktif, Mode=OneWay}"
                             Foreground="#CCD6E0" Margin="0,0,6,0" IsEnabled="False"/>
                <TextBlock Text="→" Foreground="#556" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <RadioButton Content="3.Kalibrasyon" IsChecked="{Binding Adim3Aktif, Mode=OneWay}"
                             Foreground="#CCD6E0" Margin="0,0,6,0" IsEnabled="False"/>
                <TextBlock Text="→" Foreground="#556" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <RadioButton Content="4.Hesap" IsChecked="{Binding Adim4Aktif, Mode=OneWay}"
                             Foreground="#CCD6E0" Margin="0,0,6,0" IsEnabled="False"/>
                <TextBlock Text="→" Foreground="#556" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <RadioButton Content="5.Doğrulama" IsChecked="{Binding Adim5Aktif, Mode=OneWay}"
                             Foreground="#CCD6E0" Margin="0,0,6,0" IsEnabled="False"/>
                <TextBlock Text="→" Foreground="#556" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <RadioButton Content="6.Çıktı" IsChecked="{Binding Adim6Aktif, Mode=OneWay}"
                             Foreground="#CCD6E0" IsEnabled="False"/>
            </StackPanel>
        </Border>

        <!-- İçerik -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="4,0">
            <Grid>
                <!-- Adım 1: Seçim -->
                <StackPanel Visibility="{Binding Adim1Aktif, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Adım 1 — Entity Seçimi" Foreground="White" FontWeight="Bold"
                               FontSize="14" Margin="0,0,0,12"/>
                    <TextBlock Text="DWG'deki tüm enkesit entity'lerini seçin." Foreground="#AAB2C0"
                               TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <Button Content="Entity Seç" Command="{Binding EntitySecCommand}"
                            Height="36" FontSize="13"
                            Background="#FF3D5AFE" Foreground="White" BorderThickness="0"/>
                    <TextBlock Text="{Binding EntitySayisi}" Foreground="#4CAF50"
                               Margin="0,8,0,0" FontSize="12"/>
                </StackPanel>

                <!-- Adım 2: Tarama -->
                <StackPanel Visibility="{Binding Adim2Aktif, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Adım 2 — Anchor Tarama + Pencere" Foreground="White"
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,12"/>
                    <Button Content="Anchor Tara" Command="{Binding AnchorTaraCommand}"
                            Height="32" Background="#FF3D5AFE" Foreground="White" BorderThickness="0"/>
                    <TextBlock Text="{Binding AnchorSayisi}" Foreground="#4CAF50" Margin="0,8,0,12"/>

                    <Button Content="Pencere Belirle (2 köşe tıkla)" Command="{Binding PencereBelirleCommand}"
                            Height="32" Background="#FF43A047" Foreground="White" BorderThickness="0"/>
                    <TextBlock Text="{Binding PencereBilgisi}" Foreground="#4CAF50" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Adım 3: Kalibrasyon -->
                <StackPanel Visibility="{Binding Adim3Aktif, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Adım 3 — Kalibrasyon" Foreground="White" FontWeight="Bold"
                               FontSize="14" Margin="0,0,0,12"/>
                    <TextBlock Text="Referans kesitte çizgilere rol atayın veya mevcut şablon yükleyin."
                               Foreground="#AAB2C0" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <Button Content="Kalibrasyon Aç" Command="{Binding KalibrasyonAcCommand}"
                            Height="36" Background="#FF3D5AFE" Foreground="White" BorderThickness="0"/>
                    <Button Content="Şablon Yükle (.json)" Command="{Binding SablonYukleCommand}"
                            Height="32" Margin="0,8,0,0"
                            Background="#FF546E7A" Foreground="White" BorderThickness="0"/>
                </StackPanel>

                <!-- Adım 4: Toplu Tarama -->
                <StackPanel Visibility="{Binding Adim4Aktif, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Adım 4 — Toplu Tarama + Hesap" Foreground="White"
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,12"/>
                    <Button Content="Toplu Tara" Command="{Binding TopluTaraCommand}"
                            Height="36" Background="#FF3D5AFE" Foreground="White" BorderThickness="0"/>
                    <ProgressBar Value="{Binding IlerlemeYuzde}" Height="8" Margin="0,8,0,0"
                                 Background="#FF333333" Foreground="#FF3D5AFE"/>
                    <TextBlock Text="{Binding KesitSayisi}" Foreground="#4CAF50" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Adım 5: Doğrulama -->
                <StackPanel Visibility="{Binding Adim5Aktif, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Adım 5 — Doğrulama" Foreground="White" FontWeight="Bold"
                               FontSize="14" Margin="0,0,0,12"/>
                    <TextBlock Text="Kesitleri tek tek doğrulayın, sorunluları düzeltin."
                               Foreground="#AAB2C0" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <Button Content="Doğrulama Aç" Command="{Binding DogrulamaAcCommand}"
                            Height="36" Background="#FF3D5AFE" Foreground="White" BorderThickness="0"/>
                </StackPanel>

                <!-- Adım 6: Çıktı -->
                <StackPanel Visibility="{Binding Adim6Aktif, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Adım 6 — Çıktı" Foreground="White" FontWeight="Bold"
                               FontSize="14" Margin="0,0,0,12"/>
                    <Button Content="Excel Aktar" Command="{Binding ExcelAktarCommand}"
                            Height="36" Background="#FF217A46" Foreground="White" BorderThickness="0"/>
                    <Button Content="JSON Kaydet" Command="{Binding JsonKaydetCommand}"
                            Height="32" Margin="0,8,0,0"
                            Background="#FF546E7A" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Alt: Durum + İleri/Geri -->
        <Border Grid.Row="2" Background="#FF252536" Padding="8" Margin="4">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="← Geri" Command="{Binding GeriCommand}"
                            Width="70" Height="28"
                            Background="#FF424242" Foreground="White" BorderThickness="0"/>
                    <Button Content="İleri →" Command="{Binding IleriCommand}"
                            Width="70" Height="28" Margin="6,0,0,0"
                            Background="#FF3D5AFE" Foreground="White" BorderThickness="0"/>
                </StackPanel>
                <TextBlock Text="{Binding DurumMesaji}" Foreground="#AAB2C0"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>

</UserControl>
