<UserControl x:Class="Metraj.Views.EnkesitOkuma.EnkesitOkuMainControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF1E1E2E" MinWidth="340">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Metraj;component/Views/Styles/DarkThemeStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background" Value="#FF2D2D44"/>
            <Setter Property="Foreground" Value="#FFCCCCDD"/>
            <Setter Property="BorderBrush" Value="#FF3D3D5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF3D3D5C"/>
                                <Setter Property="Foreground" Value="#FF4EC9B0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF4EC9B0"/>
                                <Setter Property="Foreground" Value="#FF1E1E2E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#FF252535"/>
                                <Setter Property="Foreground" Value="#FF555566"/>
                                <Setter Property="BorderBrush" Value="#FF2D2D44"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Background" Value="#FF4EC9B0"/>
            <Setter Property="Foreground" Value="#FF1E1E2E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF5DD9C0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Background" Value="#FF5B7FFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF7B9FFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Baslik -->
        <TextBlock Grid.Row="0" Text="Enkesit Okuma" Foreground="#FF4EC9B0" FontWeight="Bold"
                   FontSize="16" Margin="0,0,0,10"/>

        <!-- 3 Adimli Step Indicator -->
        <Border Grid.Row="1" Background="#FF2D2D44" CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <!-- Adim 1 -->
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,4,0"
                             Fill="{Binding Adim1Aktif, Converter={StaticResource BoolToVis}, FallbackValue=#FF555566}"/>
                    <TextBlock Text="Hazırlık" VerticalAlignment="Center" FontSize="12"
                               Foreground="{Binding Adim1Aktif, Converter={StaticResource BoolToVis}, FallbackValue=#FF8888AA}"/>
                </StackPanel>
                <TextBlock Text="  >  " Foreground="#FF555566" VerticalAlignment="Center"/>
                <!-- Adim 2 -->
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,4,0"
                             Fill="{Binding Adim2Aktif, Converter={StaticResource BoolToVis}, FallbackValue=#FF555566}"/>
                    <TextBlock Text="Kalibrasyon" VerticalAlignment="Center" FontSize="12"
                               Foreground="{Binding Adim2Aktif, Converter={StaticResource BoolToVis}, FallbackValue=#FF8888AA}"/>
                </StackPanel>
                <TextBlock Text="  >  " Foreground="#FF555566" VerticalAlignment="Center"/>
                <!-- Adim 3 -->
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,4,0"
                             Fill="{Binding Adim3Aktif, Converter={StaticResource BoolToVis}, FallbackValue=#FF555566}"/>
                    <TextBlock Text="Sonuç" VerticalAlignment="Center" FontSize="12"
                               Foreground="{Binding Adim3Aktif, Converter={StaticResource BoolToVis}, FallbackValue=#FF8888AA}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Icerik -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Adim 1: Hazirlik -->
                <StackPanel Visibility="{Binding Adim1Aktif, Converter={StaticResource BoolToVis}}">
                    <Button Content="Enkesitleri Seç" Command="{Binding EntitySecCommand}"
                            Style="{StaticResource DarkBtn}" Height="36"/>
                    <TextBlock Text="{Binding EntitySayisi}" Foreground="#FF4EC9B0"
                               Margin="0,6,0,0" FontSize="12"/>
                    <TextBlock Text="{Binding AnchorSayisi}" Foreground="#FF4EC9B0"
                               Margin="0,2,0,0" FontSize="12"/>
                    <TextBlock Text="{Binding PencereBilgisi}" Foreground="#FF4EC9B0"
                               Margin="0,2,0,8" FontSize="11"/>

                    <!-- Fallback: CL bulunamazsa manuel pencere -->
                    <Button Content="Manuel Pencere (Yedek)" Command="{Binding PencereBelirleCommand}"
                            Style="{StaticResource DarkBtn}" Height="28" FontSize="11" Padding="4"
                            Foreground="#FF8888AA"/>
                </StackPanel>

                <!-- Adim 2: Kalibrasyon -->
                <StackPanel Visibility="{Binding Adim2Aktif, Converter={StaticResource BoolToVis}}">
                    <Button Content="Kalibrasyon Aç" Command="{Binding KalibrasyonAcCommand}"
                            Style="{StaticResource AccentBtn}" Height="36"/>
                    <Button Content="Şablon Yükle (.json)" Command="{Binding SablonYukleCommand}"
                            Style="{StaticResource DarkBtn}" Height="32" Margin="0,8,0,0"/>

                    <!-- Ilerleme -->
                    <ProgressBar Value="{Binding IlerlemeYuzde}" Height="6" Margin="0,12,0,0"
                                 Background="#FF333333" Foreground="#FF4EC9B0"/>
                    <TextBlock Text="{Binding IlerlemeDetay}" Foreground="#FF8888AA"
                               Margin="0,4,0,0" FontSize="11"/>
                    <TextBlock Text="{Binding KesitSayisi}" Foreground="#FF4EC9B0"
                               Margin="0,2,0,0" FontSize="12"/>

                    <!-- Iptal butonu -->
                    <Button Content="İptal" Command="{Binding IptalCommand}"
                            Visibility="{Binding IptalGorunur, Converter={StaticResource BoolToVis}}"
                            Height="28" Margin="0,8,0,0" Padding="4"
                            Background="#44E24B4A" Foreground="#FFE24B4A" BorderBrush="#FFE24B4A"
                            BorderThickness="1" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Adim 3: Sonuc -->
                <StackPanel Visibility="{Binding Adim3Aktif, Converter={StaticResource BoolToVis}}">
                    <Button Content="Doğrulama Aç" Command="{Binding DogrulamaAcCommand}"
                            Style="{StaticResource PrimBtn}" Height="36"/>
                    <TextBlock Text="{Binding SonucBilgisi}" Foreground="#FF4EC9B0"
                               Margin="0,6,0,12" FontSize="12"/>

                    <Button Content="Hesapla" Command="{Binding HesaplaCommand}"
                            Style="{StaticResource DarkBtn}" Height="32"/>
                    <Button Content="Excel Aktar" Command="{Binding ExcelAktarCommand}"
                            Style="{StaticResource PrimBtn}" Height="36" Margin="0,8,0,0"/>
                    <Button Content="JSON Kaydet" Command="{Binding JsonKaydetCommand}"
                            Style="{StaticResource DarkBtn}" Height="32" Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Alt: Durum -->
        <Border Grid.Row="3" Background="#FF2D2D44" CornerRadius="4" Padding="8" Margin="0,8,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Geri" Command="{Binding GeriCommand}"
                            Style="{StaticResource DarkBtn}" Width="60" Height="26" Padding="4"/>
                    <Button Content="İleri" Command="{Binding IleriCommand}"
                            Style="{StaticResource PrimBtn}" Width="60" Height="26" Margin="6,0,0,0" Padding="4"/>
                </StackPanel>
                <TextBlock Text="{Binding DurumMesaji}" Foreground="#FF8888AA"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="11"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
