<UserControl x:Class="Metraj.Views.YolMetrajControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF1E1E2E">
    <UserControl.Resources>
        <Style x:Key="MetrajButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="#FF2D2D44" BorderBrush="#FF4D4D6C" BorderThickness="1"
                                CornerRadius="3" Padding="0,4">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="10,6" SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF3D3D5C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="6,4"/>
            <Setter Property="Background" Value="#FF4D4D6C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="{TemplateBinding Background}" Height="{TemplateBinding Height}"
                                Margin="{TemplateBinding Margin}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="50"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Sadece ekleme butonları + kaydet/yükle -->
        <DockPanel Grid.Row="0" Margin="0,0,0,4">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Kaydet" Command="{Binding KaydetCommand}"
                        Style="{StaticResource MetrajButton}" Margin="4,0,0,0" Background="#FF455A64"/>
                <Button Content="Y&#x00FC;kle" Command="{Binding YukleCommand}"
                        Style="{StaticResource MetrajButton}" Margin="4,0,0,0" Background="#FF455A64"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button Content="+ Kolon" Command="{Binding KolonEkleCommand}"
                        Style="{StaticResource MetrajButton}" Margin="0,0,4,0" Background="#FF0078D4"/>
                <Button Content="+ &#x0130;stasyon" Command="{Binding IstasyonEkleCommand}"
                        Style="{StaticResource MetrajButton}" Margin="0,0,4,0" Background="#FF107C10"/>
                <Button Content="+ Kalem" Command="{Binding KalemEkleCommand}"
                        Style="{StaticResource MetrajButton}" Margin="0,0,0,0" Background="#FF6A1B9A"/>
            </StackPanel>
        </DockPanel>

        <!-- Row 1: Kolon seçimi + Metot + Hesapla -->
        <DockPanel Grid.Row="1" Margin="0,0,0,3">
            <Button DockPanel.Dock="Right" Content="Hesapla" Command="{Binding HesaplaCommand}"
                    Style="{StaticResource MetrajButton}" Padding="10,3" Background="#FF107C10" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Kolon:" Foreground="#FFDCDCDC" FontFamily="Segoe UI" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,3,0"/>
                <ComboBox ItemsSource="{Binding Kolonlar}" SelectedItem="{Binding SeciliKolon}"
                          DisplayMemberPath="KolonHarfi" Width="50" FontSize="10" Margin="0,0,8,0"/>
                <TextBlock Text="Metot:" Foreground="#FFDCDCDC" FontFamily="Segoe UI" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,3,0"/>
                <ComboBox Width="110" FontSize="10" SelectedIndex="0" x:Name="MetotCombo"
                          SelectionChanged="MetotCombo_SelectionChanged">
                    <ComboBoxItem Content="Ortalama Alan" Tag="OrtalamaAlan"/>
                    <ComboBoxItem Content="Prismoidal" Tag="Prismoidal"/>
                </ComboBox>
            </StackPanel>
        </DockPanel>

        <!-- Row 2: İstasyonlar başlık + sağ tık ipucu -->
        <DockPanel Grid.Row="2" Margin="0,2,0,2">
            <TextBlock Text="&#x0130;stasyonlar" Foreground="#FF4EC9B0"
                       FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"/>
            <TextBlock Text="(sa&#x011F; t&#x0131;k: sil / s&#x0131;f&#x0131;rla)" Foreground="#FF666688"
                       FontFamily="Segoe UI" FontSize="9" Margin="6,0,0,0" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Row 3: İstasyon listesi + sağ tık menüsü -->
        <DataGrid Grid.Row="3" x:Name="IstasyonlarGrid"
                  ItemsSource="{Binding SeciliKolonIstasyonlari}"
                  SelectedItem="{Binding SeciliIstasyon}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  Background="#FF2D2D44" Foreground="#FFDCDCDC" BorderBrush="#FF3D3D5C"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#FF3D3D5C"
                  RowBackground="#FF2D2D44" AlternatingRowBackground="#FF252540"
                  FontSize="10" HeadersVisibility="Column" ColumnHeaderHeight="24" RowHeight="20"
                  PreviewMouseRightButtonDown="IstasyonlarGrid_PreviewMouseRightButtonDown">
            <DataGrid.ContextMenu>
                <ContextMenu Style="{StaticResource ContextMenuStyle}">
                    <MenuItem Header="Alan Ekle" Style="{StaticResource MenuItemStyle}"
                              Command="{Binding PlacementTarget.DataContext.AlanEkleCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="Alan &#x00C7;&#x0131;kar" Style="{StaticResource MenuItemStyle}"
                              Command="{Binding PlacementTarget.DataContext.AlanCikarCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator Style="{StaticResource MenuSeparatorStyle}"/>
                    <MenuItem Header="{Binding PlacementTarget.DataContext.KalemSilBaslik,
                                       RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              Style="{StaticResource MenuItemStyle}"
                              Command="{Binding PlacementTarget.DataContext.KalemSilCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="&#x0130;stasyon Sil" Style="{StaticResource MenuItemStyle}"
                              Command="{Binding PlacementTarget.DataContext.IstasyonSilCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator Style="{StaticResource MenuSeparatorStyle}"/>
                    <MenuItem Header="T&#x00FC;m &#x0130;stasyonlar&#x0131; S&#x0131;f&#x0131;rla" Style="{StaticResource MenuItemStyle}"
                              Command="{Binding PlacementTarget.DataContext.IstasyonlariSifirlaCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="Kolonu Sil" Style="{StaticResource MenuItemStyle}"
                              Command="{Binding PlacementTarget.DataContext.KolonSilCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator Style="{StaticResource MenuSeparatorStyle}"/>
                    <MenuItem Header="Hatch Temizle" Style="{StaticResource MenuItemStyle}"
                              Command="{Binding PlacementTarget.DataContext.TumHatchTemizleCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="T&#x00FC;m&#x00FC;n&#x00FC; Temizle" Style="{StaticResource MenuItemStyle}"
                              Foreground="#FFEF5350"
                              Command="{Binding PlacementTarget.DataContext.TemizleCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FF3D3D5C"/>
                    <Setter Property="Foreground" Value="#FFDCDCDC"/>
                    <Setter Property="Padding" Value="4,2"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderBrush" Value="#FF4D4D6C"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
        </DataGrid>

        <!-- Row 4: Seçili istasyon detay başlık -->
        <TextBlock Grid.Row="4" Text="Se&#x00E7;ili &#x0130;stasyon Detay&#x0131;" Foreground="#FF4EC9B0"
                   FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,2"/>

        <!-- Row 5: Katman detay -->
        <DataGrid Grid.Row="5" ItemsSource="{Binding SeciliIstasyonKatmanlari}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  Background="#FF2D2D44" Foreground="#FFDCDCDC" BorderBrush="#FF3D3D5C"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#FF3D3D5C"
                  RowBackground="#FF2D2D44" AlternatingRowBackground="#FF252540"
                  FontSize="10" HeadersVisibility="Column" ColumnHeaderHeight="24" RowHeight="20">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FF3D3D5C"/>
                    <Setter Property="Foreground" Value="#FFDCDCDC"/>
                    <Setter Property="Padding" Value="4,2"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderBrush" Value="#FF4D4D6C"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Katman" Binding="{Binding MalzemeAdi}" Width="*"/>
                <DataGridTextColumn Header="Alan (m&#x00B2;)" Binding="{Binding Alan, StringFormat=F2}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,4,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 6: Kübaj başlık -->
        <TextBlock Grid.Row="6" Text="K&#x00FC;baj Sonu&#x00E7;lar&#x0131;" Foreground="#FF4EC9B0"
                   FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,2"/>

        <!-- Row 7: Kübaj sonuçları -->
        <DataGrid Grid.Row="7" ItemsSource="{Binding MalzemeOzetleri}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  Background="#FF2D2D44" Foreground="#FFDCDCDC" BorderBrush="#FF3D3D5C"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#FF3D3D5C"
                  RowBackground="#FF2D2D44" AlternatingRowBackground="#FF252540"
                  FontSize="10" HeadersVisibility="Column" ColumnHeaderHeight="24" RowHeight="20">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FF3D3D5C"/>
                    <Setter Property="Foreground" Value="#FFDCDCDC"/>
                    <Setter Property="Padding" Value="4,2"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderBrush" Value="#FF4D4D6C"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Katman" Binding="{Binding MalzemeAdi}" Width="*"/>
                <DataGridTextColumn Header="Hacim (m&#x00B3;)" Binding="{Binding ToplamHacim, StringFormat=F2}" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,4,0"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 8: Özet -->
        <Border Grid.Row="8" Background="#FF3D3D5C" CornerRadius="3" Margin="0,3,0,0" Padding="6,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Kaz&#x0131;:" Foreground="#FF8888AA" FontFamily="Segoe UI" FontSize="9"/>
                    <TextBlock Text="{Binding ToplamKaziHacmi, StringFormat={}{0:F2} m&#x00B3;}"
                               Foreground="#FFDCDCDC" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Dolgu:" Foreground="#FF8888AA" FontFamily="Segoe UI" FontSize="9"/>
                    <TextBlock Text="{Binding ToplamDolguHacmi, StringFormat={}{0:F2} m&#x00B3;}"
                               Foreground="#FFDCDCDC" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Net:" Foreground="#FF8888AA" FontFamily="Segoe UI" FontSize="9"/>
                    <TextBlock Text="{Binding NetHacim, StringFormat={}{0:F2} m&#x00B3;}"
                               Foreground="#FF4EC9B0" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 9: Excel + durum -->
        <DockPanel Grid.Row="9" Margin="0,3,0,0">
            <Button DockPanel.Dock="Right" Content="Excel Aktar" Command="{Binding ExcelAktarCommand}"
                    Style="{StaticResource MetrajButton}" Background="#FF217A46"/>
            <TextBlock Text="{Binding DurumMesaji}" Foreground="#FF8888AA" FontFamily="Segoe UI"
                       FontSize="9" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
        </DockPanel>
    </Grid>
</UserControl>
